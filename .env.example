# Django
DEBUG=False
ALLOWED_HOSTS=.vercel.app,zentanee.vercel.app,localhost,127.0.0.1
DJANGO_SECRET_KEY=replace-with-a-strong-random-secret

# Database (required in production)
DATABASE_URL=postgresql://username:password@host:5432/dbname?sslmode=require

# Cloudinary (optional; required only if using cloud media storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Telegram admin-alert bot (signup/order notifications to owner)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=
TELEGRAM_ADMIN_WEBHOOK_SECRET=

# Telegram customer bot (channel + order flow)
TELEGRAM_CUSTOMER_BOT_TOKEN=
TELEGRAM_CUSTOMER_CHANNEL_CHAT_ID=@zentanee_channel
TELEGRAM_CUSTOMER_BOT_USERNAME=
TELEGRAM_CUSTOMER_WEBHOOK_SECRET=
